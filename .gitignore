```gitignore
# Compiled and build artifacts
*.pyc
*.class
*.o
*.exe
*.dll
*.so
*.a
*.obj
*.out
__pycache__/
*.pyo
*.pyd

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
*.env.*

# Build and distribution
dist/
build/
target/
*.min.js
*.min.css
*.bundle.js

# Logs and temporary files
*.log
*.tmp
*.temp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db
*.DS_Store
ehthumbs.db
Icon?
.directory
.Trashes
lost+found/

# Editors and IDEs
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.atom/
.atom/
*.vim
*.vimrc

# Coverage reports
coverage/
htmlcov/
.coverage
*.coveragerc

# Database
*.sqlite
*.db

# Cache directories
.cache/
.mypy_cache/
.pytest_cache/
.nyc_output/
coverage/

# WordPress specific
wp-content/cache/
*.sql
wp-config-local.php
wp-content/uploads/

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```